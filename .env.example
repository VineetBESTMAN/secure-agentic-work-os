APP_NAME=Secure Agentic AI Work OS
APP_ENV=development
APP_SECRET_KEY=change-me
APP_JWT_ALGORITHM=HS256
APP_ACCESS_TOKEN_EXPIRE_MINUTES=60
APP_REQUIRE_APPROVAL_FOR_SEND_EMAIL=true
APP_REQUIRE_APPROVAL_FOR_EXPORT=true
APP_MCP_ISSUER_URL=http://127.0.0.1:8000
APP_MCP_SERVER_URL=http://127.0.0.1:8000/protocol/mcp

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentic_work_os
APP_RUN_MIGRATIONS_ON_STARTUP=true
REDIS_URL=redis://localhost:6379/0
APP_DATABASE_PATH=backend/data/workos.db
APP_UPLOAD_DIR=backend/data/uploads

APP_ASYNC_JOBS_ENABLED=false
APP_ASYNC_JOBS_FALLBACK_SYNC=true
APP_JOB_QUEUE_NAME=ingestion
APP_JOB_TIMEOUT_SECONDS=600

APP_EMBEDDING_PROVIDER=local
APP_VECTOR_DIMENSIONS=384
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_TIMEOUT_SECONDS=20
# Set this from your provider's current price sheet; zero disables cost accrual.
OPENAI_EMBEDDING_COST_PER_MILLION_TOKENS=0
APP_DEFAULT_DAILY_COST_LIMIT_USD=5

APP_OAUTH_REDIRECT_BASE_URL=http://127.0.0.1:8000/api/connectors
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
