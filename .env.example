APP_NAME=Secure Agentic AI Work OS
APP_ENV=development
APP_SECRET_KEY=change-me
APP_JWT_ALGORITHM=HS256
APP_ACCESS_TOKEN_EXPIRE_MINUTES=60
APP_REFRESH_TOKEN_EXPIRE_DAYS=14
APP_OIDC_REDIRECT_BASE_URL=http://127.0.0.1:8000/api/auth/oidc
APP_REQUIRE_APPROVAL_FOR_SEND_EMAIL=true
APP_REQUIRE_APPROVAL_FOR_EXPORT=true
APP_MCP_ISSUER_URL=http://127.0.0.1:8000
APP_MCP_SERVER_URL=http://127.0.0.1:8000/protocol/mcp
APP_OPENCLAW_MCP_INTERNAL_URL=http://backend:8000/protocol/mcp
APP_OPENCLAW_CLIENT_DEFAULT_EXPIRY_DAYS=30
APP_OPENCLAW_CLIENT_MAX_EXPIRY_DAYS=365
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.6.6
OPENCLAW_WORKOS_TOOLS=search_documents,create_task
OPENCLAW_WORKOS_TOKEN_FILE=./.secrets/openclaw-workos-token
OPENCLAW_GATEWAY_TOKEN_FILE=./.secrets/openclaw-gateway-token

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentic_work_os
APP_RUN_MIGRATIONS_ON_STARTUP=true
REDIS_URL=redis://localhost:6379/0
APP_DATABASE_PATH=backend/data/workos.db
APP_UPLOAD_DIR=backend/data/uploads

APP_ASYNC_JOBS_ENABLED=false
APP_ASYNC_JOBS_FALLBACK_SYNC=true
APP_JOB_QUEUE_NAME=ingestion
APP_JOB_TIMEOUT_SECONDS=600

APP_EMBEDDING_PROVIDER=local
APP_VECTOR_DIMENSIONS=384
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_TIMEOUT_SECONDS=20
# Set this from your provider's current price sheet; zero disables cost accrual.
OPENAI_EMBEDDING_COST_PER_MILLION_TOKENS=0
APP_MODEL_PROVIDER=deterministic
APP_GROUNDED_ANSWERS_ENABLED=true
APP_LLM_PLANNER_ENABLED=false
APP_LLM_PLANNER_MAX_ACTIONS=8
APP_MODEL_MAX_INPUT_TOKENS=16000
OPENAI_GENERATION_MODEL=gpt-5.6
OPENAI_GENERATION_TIMEOUT_SECONDS=30
OPENAI_GENERATION_MAX_RETRIES=2
OPENAI_GENERATION_MAX_OUTPUT_TOKENS=1200
# Set these from the provider's current price sheet; zero disables cost accrual.
OPENAI_GENERATION_INPUT_COST_PER_MILLION_TOKENS=0
OPENAI_GENERATION_OUTPUT_COST_PER_MILLION_TOKENS=0
APP_DEFAULT_DAILY_COST_LIMIT_USD=5
APP_RAG_EVALUATION_MAX_CHUNKS=500

APP_OAUTH_REDIRECT_BASE_URL=http://127.0.0.1:8000/api/connectors
APP_CONNECTOR_WEBHOOK_BASE_URL=http://127.0.0.1:8000/api/connectors/webhooks
APP_CONNECTOR_OAUTH_STATE_TTL_SECONDS=600
APP_CONNECTOR_REQUEST_TIMEOUT_SECONDS=20
APP_CONNECTOR_SYNC_MAX_ITEMS=100
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PUBSUB_SERVICE_ACCOUNT=
GOOGLE_PUBSUB_AUDIENCE=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
